# ─────────────────────────────────────────────
#  Trending Aquarium — Environment Variables
#  Copy this file to .env.local and fill values
# ─────────────────────────────────────────────
#
# Supabase (get from: supabase.com → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
#DgIXSOjsoMUJOjw6
# Resend email (get from: resend.com → API Keys)
RESEND_API_KEY=re_your_api_key_here

# Business owner email (where form submissions are sent)
OWNER_EMAIL=your-email@example.com

# WhatsApp number with country code (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=``your-whatsapp-number-here``

# Google Maps Embed API key (optional — embed works without key too)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-maps-key-here
